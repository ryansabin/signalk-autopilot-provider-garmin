  {
    "id": "a9f10100c0de0090",
    "type": "function",
    "z": "32739140ce85e012",
    "name": "build pattern request",
    "func": "const TOK = 'Bearer REPLACE_WITH_YOUR_SIGNALK_TOKEN';\nmsg.method = 'PUT';\nmsg.url = 'http://localhost/signalk/v1/api/vessels/self/steering/autopilot/rudder/pattern';\nmsg.headers = { 'Authorization': TOK, 'Content-Type': 'application/json' };\nmsg.payload = { value: msg.payload };\nreturn msg;",
    "outputs": 1,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 450,
