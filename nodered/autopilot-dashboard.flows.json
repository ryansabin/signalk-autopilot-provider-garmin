    "func": "let v = msg.payload;\nif (v && typeof v === 'object' && 'value' in v) { v = v.value; }\nif (v === null || v === undefined || isNaN(v)) {\n    msg.payload = '---';\n} else {\n    let dd = v * 57.2958;\n    dd = ((dd % 360) + 360) % 360;\n    msg.payload = String(Math.round(dd)).padStart(3, '0') + String.fromCharCode(176) + ' M';\n}\nreturn msg;",
